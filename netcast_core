def extract_urls(text):
    return re.findall(r'https?://[^\s<>"\'`]+', text)

def check_phishing_phrases(text, phrase_list, score_value, findings, score):
    text_lower = text.lower()
    for phrase in phrase_list:
        if phrase.lower() in text_lower:
            score += score_value
            findings.append(f"Phishing indicator detected: {phrase}")
    return score

def check_attachment(filename):
    if not filename:
        return None
    filename = filename.lower()
    for ext in DANGEROUS_ATTACHMENTS:
        if filename.endswith(ext):
            return ext
    return None

def parse_eml_file(file_path):
    with open(file_path, "rb") as f:
        msg = email.message_from_binary_file(f)
    return msg

def detect_typosquat(domain):
    domain = domain.lower()

    if domain in TRUSTED_BRANDS:
        return None

    for brand in TRUSTED_BRANDS:
        if distance(domain, brand) <= 2:
            if domain != brand:
                return brand
    return None

