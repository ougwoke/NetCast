def domain_dns_info(domain):
    records_found, a_records, mx_records, ns_records = [], [], [], []
    for record_type in ["A", "AAAA", "MX", "NS"]:
        try:
            answers = dns.resolver.resolve(domain, record_type)
            if answers:
                records_found.append(record_type)
                if record_type == "A":
                    for rdata in answers: a_records.append(rdata.to_text())
                elif record_type == "MX":
                    for rdata in answers: mx_records.append(str(rdata.exchange).rstrip("."))
                elif record_type == "NS":
                    for rdata in answers: ns_records.append(str(rdata.target).rstrip("."))
        except Exception: pass
    return len(records_found) > 0, records_found, a_records, mx_records, ns_records

def get_spf_record(domain):
    try:
        answers = dns.resolver.resolve(domain, "TXT")
        for record in answers:
            txt = record.to_text()
            if "v=spf1" in txt.lower(): return txt
        return None
    except Exception: return None

def get_dmarc_record(domain):
    try:
        answers = dns.resolver.resolve(f"_dmarc.{domain}", "TXT")
        for record in answers:
            txt = record.to_text()
            if "v=dmarc1" in txt.lower(): return txt
        return None
    except Exception: return None

def domain_whois_info(domain):
    try:
        w = whois.whois(domain)
        return {"registrar": w.registrar, "creation_date": w.creation_date, "expiration_date": w.expiration_date, "country": w.country}
    except Exception: return None

def load_client_whitelist():
    whitelist_file = "whitelist.txt"
    whitelisted_domains = set()

    if not os.path.exists(whitelist_file):
        try:
            with open(whitelist_file, "w") as f:
                f.write("# Enter one trusted domain per line (e.g., companypartner.com)\n")
        except Exception:
            pass
        return whitelisted_domains

    try:
        with open(whitelist_file, "r") as f:
            for line in f:
                line = line.strip()
                if line and not line.startswith("#"):
                    whitelisted_domains.add(line.lower())
    except Exception as e:
        print(f"[-] Error loading whitelist.txt: {e}")

    return whitelisted_domains

# ------------LIVE SPF CHECK LOGIC ------------------------
def verify_spf_locally(domain, sender_ip):
    """
    Checks if a sender_ip is authorized by the domain's SPF record.
    """
    if not sender_ip:
        return "NONE", "No sender IP available for validation."

    try:
        answers = dns.resolver.resolve(domain, "TXT")
        spf_record = None
        for record in answers:
            txt = record.to_text().strip('"')
            if "v=spf1" in txt.lower():
                spf_record = txt
                break

        if not spf_record:
            return "NONE", "No SPF record found on domain."

        if sender_ip in spf_record:
            return "PASS", f"Sender IP {sender_ip} matched SPF record parameters."

        if "-all" in spf_record or "~all" in spf_record:
            if sender_ip not in spf_record:
                return "FAIL", "Sender IP is not authorized in domain SPF declaration."

        return "NEUTRAL", "SPF record found, but IP alignment is ambiguous."

    except Exception as e:
        return "ERROR", f"DNS lookup failed during SPF validation: {str(e)}"

