                "Quarantine the email message immediately and restrict access to security personnel.",
                "Detonate attachments or links in an isolated sandbox environment to observe behavioral execution.",
                "Verify the 'Received' routing headers manually to confirm delivery path alignment."
            ],
            "NEEDS REVIEW": [
                "Check for technical delivery gaps (missing SPF/DMARC records) or highly volatile domain age.",
                "Confirm authenticity with the purported sender using an alternative, verified communication channel.",
                "Apply an external warning banner to the message body if it must be released to the recipient."
            ],
            "LEGITIMATE": [
                "Proceed with standard mailbox delivery.",
                "Monitor for future delivery anomalies, or adjust baseline rules if this source requires whitelisting."
            ]
        }
        return email_recs.get(verdict, ["Review the specific indicator anomalies listed in the findings report."])

# ================= RUN =================
def run(target, target_type):
    score, verdict, findings = analyse_target(target, target_type)
    print(f"\nScan Verdict: {verdict} (Score: {score}/100)")
    for finding in findings:
        print(f" - {finding}")

# ================= MENU =================
def interactive_menu():
    print_banner()
    print("1. Scan Domain")
    print("2. Scan Email Texts (Multi-line Input Supported)")
    print("3. Scan Email File (.eml)")
    print("4. Exit")

    choice = input("\nSelect option (1-4): ").strip()

    if choice == "1":
        run(input("Enter domain: ").strip(), "domain")
    elif choice == "2":
        print("\nEnter or paste your raw email text below. To submit for scanning, type 'DONE' on a new line and press Enter:\n" + "-"*60)
        lines = []
        while True:
            line = input()
            if line.strip().upper() == "DONE": break
            lines.append(line)
        email_content = "\n".join(lines).strip()
        if email_content: run(email_content, "email_text")
        else:
            print("Empty input. Returning to menu..."); interactive_menu()
    elif choice == "3":
        run(input("Enter path to .eml file: ").strip(), "email_file")
    elif choice == "4":
        sys.exit(0)
    else:
        interactive_menu()

if __name__ == "__main__":
    interactive_menu()
